<?xml version='1.0' ?>
<!-- headless slotcar 3대 bring-up. pinky1@v0, pinky2@v8, pinky3@v5.
     slotcar 이름 = spawn -name (Gazebo 모델명) → /robot_state 의 name 으로 구분. -->
<launch>
    <arg name="world_name" default="new_map.sdf"/>
    <arg name="world" default="$(find-pkg-share pinky_gz_sim)/worlds/$(var world_name)"/>
    <arg name="bridge_params" default="$(find-pkg-share pinky_gz_sim)/params/pinky_bridge.yaml"/>
    <arg name="building_yaml"/>
    <arg name="gui" default="false"/>   <!-- true 면 Gazebo GUI 창도 띄움(run_sim.sh) -->

    <set_env name="GZ_SIM_RESOURCE_PATH" value="$(find-pkg-share pinky_description)/../:/$(find-pkg-share pinky_gz_sim)/models:/$(env HOME)/.gazebo/models"/>
    <set_env name="GZ_SIM_SYSTEM_PLUGIN_PATH" value="/opt/ros/jazzy/lib/rmf_robot_sim_gz_plugins:$(env GZ_SIM_SYSTEM_PLUGIN_PATH '')"/>

    <node pkg="rmf_building_map_tools" exec="building_map_server" name="building_map_server"
          args="$(var building_yaml)" output="screen"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name='gz_args' value='-r -s -v3 $(var world)'/>
        <arg name='on_exit_shutdown' value='true'/>
    </include>

    <!-- GUI 창 (gui:=true 일 때만) -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py" if="$(var gui)">
        <arg name='gz_args' value='-g -v2'/>
    </include>

    <include file="$(find-pkg-share pinky_description)/launch/upload_robot.launch.py">
        <arg name='use_sim_time' value='True'/>
        <arg name='is_sim' value='True'/>
        <arg name='drive' value='slotcar'/>
    </include>

    <node pkg="ros_gz_sim" exec="create" name='create1' output='screen'
          args="-name pinky1 -topic /robot_description -x -3.876 -y 11.209 -z 0.1">
        <param name='use_sim_time' value='True'/>
    </node>
    <node pkg="ros_gz_sim" exec="create" name='create2' output='screen'
          args="-name pinky2 -topic /robot_description -x 0.522 -y 0.109 -z 0.1">
        <param name='use_sim_time' value='True'/>
    </node>
    <node pkg="ros_gz_sim" exec="create" name='create3' output='screen'
          args="-name pinky3 -topic /robot_description -x -3.577 -y 3.307 -z 0.1">
        <param name='use_sim_time' value='True'/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name='parameter_bridge' output='screen'
          args="--ros-args -p config_file:=$(var bridge_params)"/>
</launch>
